{
  "header": {
    "prefix": "header",
    "body": [
      "# =============================================================================",
      "# File        : $TM_FILENAME",
      "# Author      : ${1:yukimemi}",
      "# Last Change : $CURRENT_YEAR/$CURRENT_MONTH/$CURRENT_DATE $CURRENT_HOUR:$CURRENT_MINUTE:$CURRENT_SECOND.",
      "# =============================================================================",
      "${0}",
      ""
    ]
  },
  "plugin": {
    "prefix": "plugin",
    "body": [
      "[[plugins]]",
      "repo = '${1:$TM_SELECTED_TEXT}'",
      "if = 0",
      "on_event = ['CursorHold', 'FocusLost']",
      "hook_add = '''",
      "source \\$VIM_PATH/rc/${2:$TM_SELECTED_TEXT}.vim",
      "'''",
      ""
    ]
  }
}
