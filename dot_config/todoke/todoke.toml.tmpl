# chezmoi:template:left-delimiter="<%" right-delimiter="%>"
# todoke config. Managed by chezmoi.
# Deploys to ~/.config/todoke/todoke.toml on every platform.
#
# Chezmoi uses custom delimiters above so Tera's native double-brace
# expressions and percent-tag blocks, plus TOML's array-of-tables
# headers, all pass through chezmoi untouched. Todoke pre-renders the
# Tera bits at dispatch time.
#
# The whole file is pre-rendered through Tera before TOML parsing, so if/elif
# /else/endif blocks can conditionally include entire target or rule
# sections. Dispatch-time tokens like {{ group }} / {{ file_path }} pass
# through pre-render intact and get rendered per-input by todoke at dispatch
# time.

[vars]
# Which Neovim front-end to use for main editing. Selected by chezmoi
# from the same .autohotkey.use* flags that drive the AutoHotkey F10
# hotkey, so both stay in sync.
<%- if .autohotkey.useneovide %>
gui = "neovide"
<%- else if .autohotkey.useneovimqt %>
gui = "nvim-qt"
<%- else if eq .autohotkey.purpose "home" %>
gui = "neovide"
<%- else %>
gui = "nvim"
<%- end %>
# nvim front-ends that are "wrappers" — they run an embedded nvim and
# forward CLI args after `--` to it. Raw `nvim` doesn't want `--` since it
# treats everything after as filenames. Listing wrappers here lets the
# single [todoke.gui] definition below handle all three variants.
wrapper_guis = ["neovide", "nvim-qt"]

# ─── Targets ────────────────────────────────────────────────────────────────
# todoke.<name> is a delivery target. `kind` defaults to "exec" (just spawn
# the command). Set `kind = "neovim"` to opt into msgpack-RPC reuse.

# Primary editor, selected by vars.gui. A single definition covers nvim,
# neovide, and nvim-qt — the `--` passthrough separator is only injected
# when the chosen command is a wrapper.
[todoke.gui]
kind = "neovim"
command = "{{ vars.gui }}"
listen = '{% if is_windows() %}\\.\pipe\nvim-todoke-{{ group }}{% else %}/tmp/nvim-todoke-{{ group }}.sock{% endif %}'
# Suppress the transient cmd window on Windows when the chosen front-end
# is a GUI wrapper (neovide / nvim-qt). Raw `nvim` stays on the console
# path so it keeps getting a properly wired fresh terminal.
gui = {{ vars.gui in vars.wrapper_guis }}

{% if vars.gui in vars.wrapper_guis %}
[todoke.gui.args]
remote = ["--"]
{% endif %}

# Terminal nvim, always available for $EDITOR-callback files (commit
# messages, rebase todos, …). Independent of vars.gui so short blocking
# edits stay in the calling terminal even when the GUI is in use.
[todoke.nvim-term]
kind = "neovim"
command = "nvim"
listen = '{% if is_windows() %}\\.\pipe\nvim-todoke-{{ group }}-term{% else %}/tmp/nvim-todoke-{{ group }}-term.sock{% endif %}'

# ─── Rules ──────────────────────────────────────────────────────────────────

# $EDITOR-callback files — always terminal nvim, fresh instance, block
# until it exits. Pattern list is OR-ed; grouped by origin so the intent
# is readable and easy to extend.
[[rules]]
name = "editor-callback"
match = [
  # git
  '(?i)/(COMMIT_EDITMSG|MERGE_MSG|TAG_EDITMSG|EDIT_DESCRIPTION|git-rebase-todo|NOTES_EDITMSG|\.gitmessage)$',
  # svn / hg
  '(?i)/svn-commit\.tmp$',
]
to = "nvim-term"
mode = "new"
sync = true

[[rules]]
name = "editor-callback-gui"
match = [
  # Claude Code prompt temp files
  '(?i)/claude-prompt-.*$',
]
to = "gui"
mode = "new"
sync = true

# Everything else: route to whichever target vars.gui resolved above.
[[rules]]
name = "default"
match = '.*'
to = "gui"
group = "default"
mode = "remote"
sync = false
