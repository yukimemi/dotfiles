{{- $purpose := "home" -}}
{{- if (hasKey . "autohotkey") -}}
{{-   $purpose = promptStringOnce .autohotkey "purpose" "Enter purpose (home/work)" "home" -}}
{{- else -}}
{{-   $purpose = promptString "Enter purpose (home/work)" "home" -}}
{{- end -}}

[diff]
    {{- if lookPath "bat" }}
    pager = "bat"
    {{- else }}
    pager = "less"
    {{- end }}

[merge]
    command = "nvim"
    args = ["-d", "{{ "{{" }} .Destination {{ "}}" }}", "{{ "{{" }} .Source {{ "}}" }}"]

[data.autohotkey]
    purpose = {{ $purpose | quote }}
